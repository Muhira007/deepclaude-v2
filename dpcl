#!/usr/bin/env bash
#
# dpcl — run Claude Code against DeepSeek's Anthropic-compatible API.
#
# Key resolution order:
#   1. `dpcl config [KEY]`     — set/replace the stored key (inline or prompt)
#   2. stored config file            — set on a previous run
#   3. DEEPSEEK_API_KEY env var      — used and saved for next time
#   4. interactive prompt            — asks for the key if you haven't included it yet
#
set -euo pipefail

VERSION="1.0.0"

# --- paths -------------------------------------------------------------------
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/dpcl"
CONFIG_FILE="$CONFIG_DIR/config"

# --- defaults ----------------------------------------------------------------
DEFAULT_MODEL="deepseek-v4-pro[1m]"
DEFAULT_HAIKU_MODEL="deepseek-v4-flash"
DEFAULT_SUBAGENT_MODEL="deepseek-v4-flash"
DEFAULT_EFFORT="max"

# --- helpers -----------------------------------------------------------------
say()   { printf '%s\n' "$*" >&2; }
die()   { say "ERROR: $*"; exit 1; }
warn()  { say "WARNING: $*"; }
debug() { [ "${DPCL_VERBOSE:-0}" = "1" ] && say "[DEBUG] $*" || true; }

trim() {
  local s="$1"
  s="${s#"${s%%[![:space:]]*}"}"
  s="${s%"${s##*[![:space:]]}"}"
  printf '%s' "$s"
}

# --- config file I/O ---------------------------------------------------------
# Read a key from the config file. Usage: read_config KEY_NAME
read_config() {
  local want="$1"
  [ -f "$CONFIG_FILE" ] || return 1
  local line
  while IFS= read -r line || [ -n "$line" ]; do
    case "$line" in
      "${want}="*) printf '%s' "${line#"${want}="}"; return 0 ;;
    esac
  done < "$CONFIG_FILE"
  return 1
}

# Write/update a key=value pair in the config file.
write_config() {
  local key="$1" value="$2"
  mkdir -p "$CONFIG_DIR"
  if [ -f "$CONFIG_FILE" ] && grep -q "^${key}=" "$CONFIG_FILE" 2>/dev/null; then
    # Update existing key
    local tmp; tmp="$(mktemp)"
    while IFS= read -r line || [ -n "$line" ]; do
      case "$line" in
        "${key}="*) printf '%s=%s\n' "$key" "$value" ;;
        *) printf '%s\n' "$line" ;;
      esac
    done < "$CONFIG_FILE" > "$tmp"
    mv "$tmp" "$CONFIG_FILE"
  else
    # Append new key
    printf '%s=%s\n' "$key" "$value" >> "$CONFIG_FILE"
  fi
  chmod 600 "$CONFIG_FILE" 2>/dev/null || true
}

save_key() {
  local key
  key="$(trim "$1")"
  if [ -z "$key" ]; then
    die "Refusing to save an empty key."
  fi
  if ! validate_key_format "$key"; then
    warn "Key format looks unusual (expected 'sk-...' prefix)."
    warn "Saving anyway, but it may not work."
  fi
  write_config "DEEPSEEK_API_KEY" "$key"
  say "Key saved to $CONFIG_FILE"
}

read_key() {
  read_config "DEEPSEEK_API_KEY" 2>/dev/null || true
}

# --- key validation ----------------------------------------------------------
validate_key_format() {
  local key="$1"
  [[ "$key" =~ ^sk-[a-zA-Z0-9]+ ]] && return 0
  return 1
}

verify_key_api() {
  local key="$1"
  say "Verifying API key..."
  if ! command -v curl >/dev/null 2>&1; then
    warn "curl not found; skipping API validation."
    return 2
  fi
  local http_code
  http_code=$(curl -s -o /dev/null -w "%{http_code}" \
    --max-time 10 \
    -H "Authorization: Bearer ${key}" \
    "https://api.deepseek.com/v1/models" 2>/dev/null || echo "000")

  case "$http_code" in
    200) say "✓ API key is valid."; return 0 ;;
    401) say "✗ API key is invalid or expired (HTTP 401)."; return 1 ;;
    403) say "✗ API key lacks permissions (HTTP 403)."; return 1 ;;
    000) warn "Could not reach DeepSeek API (network error)."; return 2 ;;
    *)   warn "Unexpected response (HTTP $http_code). Key may still work."; return 2 ;;
  esac
}

# --- interactive setup -------------------------------------------------------
interactive_setup() {
  say ""
  say "┌──────────────────────────────────────────┐"
  say "│  dpcl · first-time setup            │"
  say "└──────────────────────────────────────────┘"
  say ""
  say "Claude Code will run against DeepSeek's API."
  say "You only need to enter your key once."
  say "Get a key: https://platform.deepseek.com/api_keys"
  say ""
  local key="" tries=0
  while :; do
    key="$(trim "$(read_secret 'DeepSeek API key: ')")"
    if [ -n "$key" ]; then
      if ! validate_key_format "$key"; then
        warn "Key should start with 'sk-'. Please double-check."
        say ""
      fi
      break
    fi
    tries=$((tries + 1))
    say "Key can't be empty."
    if [ "$tries" -ge 3 ]; then
      die "Aborting after 3 empty attempts."
    fi
  done
  save_key "$key"
  say ""
  say "Key saved. Verifying..."
  verify_key_api "$key" || true
  say ""
}

# Read a secret from the terminal; fall back to stdin if /dev/tty is unusable.
read_secret() {
  local prompt="$1" value=""
  printf '%s' "$prompt" >&2
  if IFS= read -rs value 2>/dev/null < /dev/tty; then
    :
  else
    IFS= read -rs value || true
  fi
  printf '\n' >&2
  printf '%s' "$value"
}

# --- help --------------------------------------------------------------------
show_help() {
  cat <<'EOF'
dpcl — run Claude Code against DeepSeek's Anthropic-compatible API.

USAGE
  dpcl [FLAGS] [--] [ARGUMENTS...]

FLAGS
  --help, help       Show this help message
  --version          Show version number
  --dry-run          Print what would be executed, without running Claude Code
  --verbose          Print debug information during execution
  --safe             Run WITHOUT --dangerously-skip-permissions (more prompts)

SUBCOMMANDS
  dpcl config [KEY]       Set or change the stored API key
  dpcl change-key [KEY]   Alias for config
  dpcl reset              Delete the stored API key
  dpcl update             Update to the latest version
  dpcl verify             Verify the stored API key against DeepSeek API
  dpcl show-config        Print current configuration (key masked)

KEY RESOLUTION ORDER
  1. dpcl config <KEY>
  2. Stored config file (~/.config/dpcl/config)
  3. DEEPSEEK_API_KEY environment variable (auto-saved on use)
  4. Interactive prompt

ENVIRONMENT VARIABLES
  DEEPSEEK_API_KEY              DeepSeek API key (saved automatically on first use)
  DPCL_SAFE=1             Same as --safe (skip --dangerously-skip-permissions)
  DPCL_VERBOSE=1          Same as --verbose
  DPCL_MODEL              Default model (default: deepseek-v4-pro[1m])
  DPCL_HAIKU_MODEL        Haiku/flash model (default: deepseek-v4-flash)
  DPCL_SUBAGENT_MODEL     Subagent model (default: deepseek-v4-flash)
  DPCL_EFFORT             Effort level (default: max)

CONFIG FILE
  Path:  ~/.config/dpcl/config  (chmod 600)
  Format: KEY=VALUE (one per line)

  Customize models in the config file:
    DPCL_MODEL=deepseek-v4-pro[1m]
    DPCL_HAIKU_MODEL=deepseek-v4-flash
    DPCL_SUBAGENT_MODEL=deepseek-v4-flash
    DPCL_EFFORT=max
    DPCL_SAFE=1

  Or set them per-session as environment variables.

EXAMPLES
  dpcl                              # First run: enter key, then start
  dpcl "refactor this module"       # Pass a prompt to Claude Code
  dpcl --safe "rm -rf ./build"      # Run with permission prompts enabled
  dpcl --dry-run --verbose          # Preview what will be set
  dpcl config sk-xxx                # Set key without interactive prompt
  dpcl verify                       # Check if your stored key works
  dpcl show-config                  # See current settings
  DPCL_MODEL=other-model dpcl # Override model for one session
EOF
  exit 0
}

# --- show config -------------------------------------------------------------
show_config() {
  local key saved_safe
  key="$(read_key || true)"
  saved_safe="$(read_config "DPCL_SAFE" 2>/dev/null || echo "0")"

  echo "Config file : $CONFIG_FILE"
  echo "Config dir  : $CONFIG_DIR"
  echo "---"
  echo "API key     : ${key:+(stored, ${#key} chars)}"
  echo "Safe mode   : ${DPCL_SAFE:-$saved_safe}"
  echo "---"
  echo "Model overrides (from config or env):"
  echo "  MODEL        : ${DPCL_MODEL:-$(read_config "DPCL_MODEL" 2>/dev/null || echo "$DEFAULT_MODEL")}"
  echo "  HAIKU_MODEL  : ${DPCL_HAIKU_MODEL:-$(read_config "DPCL_HAIKU_MODEL" 2>/dev/null || echo "$DEFAULT_HAIKU_MODEL")}"
  echo "  SUBAGENT     : ${DPCL_SUBAGENT_MODEL:-$(read_config "DPCL_SUBAGENT_MODEL" 2>/dev/null || echo "$DEFAULT_SUBAGENT_MODEL")}"
  echo "  EFFORT       : ${DPCL_EFFORT:-$(read_config "DPCL_EFFORT" 2>/dev/null || echo "$DEFAULT_EFFORT")}"
  exit 0
}

# --- dry run -----------------------------------------------------------------
do_dry_run() {
  local key safe_mode model haiku_model subagent_model effort
  key="$(read_key || true)"
  safe_mode="${DPCL_SAFE:-$(read_config "DPCL_SAFE" 2>/dev/null || echo "0")}"
  model="${DPCL_MODEL:-$(read_config "DPCL_MODEL" 2>/dev/null || echo "$DEFAULT_MODEL")}"
  haiku_model="${DPCL_HAIKU_MODEL:-$(read_config "DPCL_HAIKU_MODEL" 2>/dev/null || echo "$DEFAULT_HAIKU_MODEL")}"
  subagent_model="${DPCL_SUBAGENT_MODEL:-$(read_config "DPCL_SUBAGENT_MODEL" 2>/dev/null || echo "$DEFAULT_SUBAGENT_MODEL")}"
  effort="${DPCL_EFFORT:-$(read_config "DPCL_EFFORT" 2>/dev/null || echo "$DEFAULT_EFFORT")}"

  echo "═══════════════════════════════════════════════"
  echo "  dpcl dry-run"
  echo "═══════════════════════════════════════════════"
  echo ""
  echo "Would set these environment variables:"
  echo ""
  printf "  %-36s %s\n" "ANTHROPIC_BASE_URL" "https://api.deepseek.com/anthropic"
  printf "  %-36s %s\n" "ANTHROPIC_AUTH_TOKEN" "${key:+(hidden, ${#key} chars)}"
  printf "  %-36s %s\n" "ANTHROPIC_MODEL" "$model"
  printf "  %-36s %s\n" "ANTHROPIC_DEFAULT_OPUS_MODEL" "$model"
  printf "  %-36s %s\n" "ANTHROPIC_DEFAULT_SONNET_MODEL" "$model"
  printf "  %-36s %s\n" "ANTHROPIC_DEFAULT_HAIKU_MODEL" "$haiku_model"
  printf "  %-36s %s\n" "CLAUDE_CODE_SUBAGENT_MODEL" "$subagent_model"
  printf "  %-36s %s\n" "CLAUDE_CODE_EFFORT_LEVEL" "$effort"
  echo ""
  if [ "$safe_mode" = "1" ]; then
    echo "Would run: claude $*"
  else
    echo "Would run: claude --dangerously-skip-permissions $*"
  fi
  echo ""
  if [ "$safe_mode" != "1" ]; then
    echo "⚠  --dangerously-skip-permissions is ENABLED (use --safe to disable)"
  else
    echo "✓  Safe mode: tools will require per-action approval"
  fi
  exit 0
}

# --- subcommands -------------------------------------------------------------
handle_subcommand() {
  case "${1:-}" in
    config|--config|set-key|--set-key|change|--change|change-key|--change-key)
      if [ "${2:-}" != "" ]; then
        save_key "$2"
      else
        interactive_setup
      fi
      say "Done. Run 'dpcl' to start."
      exit 0
      ;;
    reset|--reset)
      if [ -f "$CONFIG_FILE" ]; then
        rm -f "$CONFIG_FILE"
        say "Stored key removed ($CONFIG_FILE)."
      else
        say "No stored key to remove."
      fi
      exit 0
      ;;
    update|--update|upgrade|--upgrade)
      say "Updating dpcl to the latest version..."
      curl -fsSL "https://raw.githubusercontent.com/Muhira007/deepclaude-v2/main/install.sh" | bash
      exit $?
      ;;
    verify|--verify)
      local key; key="$(read_key || true)"
      if [ -z "$key" ]; then
        die "No stored key. Run 'dpcl config' first."
      fi
      say "Stored key: ${key:0:5}...${key: -4} (${#key} chars)"
      if validate_key_format "$key"; then
        say "Format:  ✓ (starts with sk-)"
      else
        warn "Format:  ✗ (expected sk-... prefix)"
      fi
      verify_key_api "$key" || true
      exit 0
      ;;
    show-config|--show-config|show|--show)
      show_config
      ;;
    help|--help|-h)
      show_help
      ;;
  esac
}

# ============================================================================
# MAIN
# ============================================================================

# Parse dpcl-specific flags from the front of the argument list.
DRY_RUN=0
PASSTHROUGH_ARGS=()

while [ $# -gt 0 ]; do
  case "$1" in
    --help|help|-h)
      show_help
      ;;
    --version)
      echo "dpcl v$VERSION"
      exit 0
      ;;
    --dry-run)
      DRY_RUN=1
      shift
      ;;
    --verbose)
      DPCL_VERBOSE=1
      export DPCL_VERBOSE
      shift
      ;;
    --safe)
      DPCL_SAFE=1
      export DPCL_SAFE
      shift
      ;;
    --)
      shift
      PASSTHROUGH_ARGS+=("$@")
      break
      ;;
    config|--config|set-key|--set-key|change|--change|change-key|--change-key|\
    reset|--reset|update|--update|upgrade|--upgrade|\
    verify|--verify|show-config|--show-config|show|--show)
      handle_subcommand "$@"
      ;;
    *)
      PASSTHROUGH_ARGS+=("$1")
      shift
      ;;
  esac
done

debug "dpcl v$VERSION starting"
debug "CONFIG_FILE=$CONFIG_FILE"
debug "DRY_RUN=$DRY_RUN"
debug "DPCL_SAFE=${DPCL_SAFE:-0}"
debug "DPCL_VERBOSE=${DPCL_VERBOSE:-0}"

# --- resolve the key ---------------------------------------------------------
KEY="$(read_key || true)"
debug "Key from config: ${KEY:+found (${#KEY} chars)}"

# Not stored yet: take it from the environment if it's there...
if [ -z "${KEY:-}" ] && [ -n "${DEEPSEEK_API_KEY:-}" ]; then
  KEY="$(trim "$DEEPSEEK_API_KEY")"
  say "Using DEEPSEEK_API_KEY from environment; saving for next time."
  if ! save_key "$KEY"; then
    warn "Could not save key to $CONFIG_FILE (disk full or permission issue?)."
    warn "Key will only be used for this session."
  fi
fi

# ...otherwise ask for it interactively.
if [ -z "${KEY:-}" ]; then
  interactive_setup
  KEY="$(read_key || true)"
fi

if [ -z "${KEY:-}" ]; then
  die "No API key available. Run 'dpcl config' to set one."
fi

debug "Key resolved (${#KEY} chars)"

# --- resolve model overrides -------------------------------------------------
# Priority: env var > config file > built-in default
MODEL="${DPCL_MODEL:-$(read_config "DPCL_MODEL" 2>/dev/null || echo "$DEFAULT_MODEL")}"
HAIKU_MODEL="${DPCL_HAIKU_MODEL:-$(read_config "DPCL_HAIKU_MODEL" 2>/dev/null || echo "$DEFAULT_HAIKU_MODEL")}"
SUBAGENT_MODEL="${DPCL_SUBAGENT_MODEL:-$(read_config "DPCL_SUBAGENT_MODEL" 2>/dev/null || echo "$DEFAULT_SUBAGENT_MODEL")}"
EFFORT="${DPCL_EFFORT:-$(read_config "DPCL_EFFORT" 2>/dev/null || echo "$DEFAULT_EFFORT")}"
SAFE_MODE="${DPCL_SAFE:-$(read_config "DPCL_SAFE" 2>/dev/null || echo "0")}"

debug "MODEL=$MODEL"
debug "HAIKU_MODEL=$HAIKU_MODEL"
debug "SUBAGENT_MODEL=$SUBAGENT_MODEL"
debug "EFFORT=$EFFORT"
debug "SAFE_MODE=$SAFE_MODE"

# --- dry-run early exit ------------------------------------------------------
if [ "$DRY_RUN" = "1" ]; then
  do_dry_run "${PASSTHROUGH_ARGS[@]}"
fi

# --- launch ------------------------------------------------------------------
if ! command -v claude >/dev/null 2>&1; then
  die "claude CLI not found on PATH.\nInstall Claude Code first: https://docs.claude.com/en/docs/claude-code"
fi

export ANTHROPIC_BASE_URL="https://api.deepseek.com/anthropic"
export ANTHROPIC_AUTH_TOKEN="$KEY"
export ANTHROPIC_MODEL="$MODEL"
export ANTHROPIC_DEFAULT_OPUS_MODEL="$MODEL"
export ANTHROPIC_DEFAULT_SONNET_MODEL="$MODEL"
export ANTHROPIC_DEFAULT_HAIKU_MODEL="$HAIKU_MODEL"
export CLAUDE_CODE_SUBAGENT_MODEL="$SUBAGENT_MODEL"
export CLAUDE_CODE_EFFORT_LEVEL="$EFFORT"

debug "Environment variables set. Launching claude..."

if [ "$SAFE_MODE" = "1" ]; then
  say "Running in safe mode (permission prompts enabled)."
  exec claude "${PASSTHROUGH_ARGS[@]}"
else
  exec claude --dangerously-skip-permissions "${PASSTHROUGH_ARGS[@]}"
fi
